# Gyan AI Pipeline — Required Environment Variables
# Copy this file to .env and fill in your values for local development.
# NEVER commit your actual .env file — it is in .gitignore.
#
# For GitHub Actions: set these in
#   Repo → Settings → Secrets and variables → Actions → New repository secret
#
# For Streamlit Cloud: set these in
#   App settings → Secrets (TOML format)

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...

# ── Groq LLM ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...your-groq-api-key...
GROQ_MODEL=llama-3.3-70b-versatile

# ── Sarvam AI (optional — for Indic language features) ───────────────────────
SARVAM_API_KEY=

# ── GitHub (used by Streamlit admin to trigger Actions workflows) ─────────────
# Generate at: github.com/settings/tokens → Fine-grained token
# Required scope: Actions (read + write) on this repo only
GITHUB_PAT=github_pat_...
GITHUB_REPO=arkagimt/gyan-ai-pipeline
