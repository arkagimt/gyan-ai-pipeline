# Gyan AI Pipeline — Required Environment Variables
# Copy this file to .env and fill in your values for local development.
# NEVER commit your actual .env file — it is in .gitignore.
#
# For GitHub Actions: set these in
#   Repo → Settings → Secrets and variables → Actions → New repository secret
#
# For Streamlit Cloud: set these in
#   App settings → Secrets (TOML format)

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...

# ── Groq LLM ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...your-groq-api-key...
GROQ_MODEL=llama-3.3-70b-versatile

# ── Sarvam AI — Indic-native LLM for Bengali/Hindi content ──────────────────
# Required for WBBSE / WBCHSE boards to generate proper Bengali MCQs.
# Without this, pipeline falls back to Groq/Llama (weaker Bengali).
# Get key: https://www.sarvam.ai/
SARVAM_API_KEY=
SARVAM_MODEL=sarvam-m

# ── Groq safety model (Llama Guard 3) ────────────────────────────────────────
# Default is correct — only change if Groq renames the model.
GROQ_GUARD_MODEL=llama-guard-3-8b

# ── Observability (optional — Arize Phoenix tracing) ─────────────────────────
# Local: run `python -m phoenix.server.main` then set to http://localhost:6006
# Leave empty to disable tracing (no performance impact when empty).
PHOENIX_ENDPOINT=

# ── GitHub (used by Streamlit admin to trigger Actions workflows) ─────────────
# Generate at: github.com/settings/tokens → Fine-grained token
# Required scope: Actions (read + write) on this repo only
GITHUB_PAT=github_pat_...
GITHUB_REPO=arkagimt/gyan-ai-pipeline
